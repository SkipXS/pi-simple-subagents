  "description": "Small, opinionated Pi extension for plan-driven subagent orchestration with scout, worker, and fresh reviewers.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "orchestrator",
    "subagents",
    "agents"
  ],
  "pi": {
    "extensions": [
      "./extensions/pi-simple-subagents"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.78.0",
    "typebox": "^1.1.39"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.78.0 <1"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "extensions/",
    "examples/",
    "README.md",
    "LICENSE"
  ]
}
