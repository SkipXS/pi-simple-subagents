{
  "roles": {
    "orchestrator": {
      "model": "openai-codex/gpt-5.5",
      "thinking": "high"
    },
    "scout": {
      "model": "openai-codex/gpt-5.3-codex-spark",
      "thinking": "low"
    },
    "worker": {
      "model": "openai-codex/gpt-5.5",
      "thinking": "medium"
    },
    "reviewer": {
      "model": "openai-codex/gpt-5.5",
      "thinking": "high"
    }
  },
  "children": {
    "forwardCurrentExtension": "auto",
    "timeoutMs": 1800000
  },
  "references": {
    "maxFileBytes": 1048576,
    "allowOutsideCwd": false,
    "allowBinary": false
  },
  "artifacts": {
    "baseDir": ".pi/agent-runs"
  }
}
